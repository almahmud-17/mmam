# ============================================
# Express API — Render / লোকাল
# Neon → Connection string → DATABASE_URL
# ============================================

# Neon PostgreSQL (প্রোডাকশন). লোকালে ও একই ফরম্যাট ব্যবহার করতে পারেন।
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

JWT_SECRET="এখানে_লম্বা_র্যান্ডম_স্ট্রিং_প্রোডাকশনে_অবশ্যই_বদলাবেন"

# CORS: Vercel সাইটের সম্পূর্ণ URL। Preview ব্রাঞ্চ চালু রাখতে কমা দিয়ে একাধিক URL:
# FRONTEND_URL="https://your-app.vercel.app,https://your-app-git-main-xxx.vercel.app"
FRONTEND_URL="http://localhost:3000"

# Render এ PORT সেট করবেন না — প্ল্যাটফর্ম দেয়। লোকালে ঐচ্ছিক:
# PORT=5001
