// ================================================================
// DATABASE SCHEMA - School Management System
// Technology: Prisma ORM + SQLite (dev) / PostgreSQL (prod)
// ================================================================

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------
// Enums & Shared Types
// -----------------------------------------------------------------
// SQLite does not support native enums, normally we would use them
// in PostgreSQL. For Prisma + SQLite we handle them as Strings,
// but define consts in code.
//
// Role values:    "ADMIN" | "TEACHER" | "STUDENT"
// Attendance:     "PRESENT" | "ABSENT" | "LATE"
// Notice type:    "GENERAL" | "ACADEMIC" | "EMERGENCY"
// Exam types:     "CLASS_TEST" | "MID" | "FINAL"
// -----------------------------------------------------------------

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed with bcrypt
  role      String   // ADMIN, TEACHER, STUDENT
  name      String
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile Student?
  teacherProfile Teacher?

  messagesSent     Message[] @relation("Sender")
  messagesReceived Message[] @relation("Receiver")
}

model Class {
  id       String    @id @default(uuid())
  name     String    // e.g. "Class 10"
  sections Section[]
}

model Section {
  id      String @id @default(uuid())
  name    String // e.g. "A"
  classId String
  class   Class  @relation(fields: [classId], references: [id])

  students Student[]
  subjects Subject[]
}

model Subject {
  id        String  @id @default(uuid())
  name      String  // e.g. "Mathematics"
  code      String
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id])

  teacherId String?
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  marks       Mark[]
  assignments Assignment[]
  attendances Attendance[]
}

model Student {
  id     String @id @default(cuid()) // Format: STU-XXX handled in app
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rollNo    Int
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id])

  marks       Mark[]
  attendances Attendance[]
  submissions Submission[]
}

model Teacher {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  specialization String?
  subjects       Subject[]
}

model Attendance {
  id     String   @id @default(uuid())
  date   DateTime
  status String   // PRESENT, ABSENT, LATE

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id])

  createdAt DateTime @default(now())
}

model Mark {
  id         String @id @default(uuid())
  examType   String // CLASS_TEST, MID, FINAL
  score      Float
  totalScore Float

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Assignment {
  id          String    @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime
  fileUrl     String?   // Links to uploaded PDF/Images

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  submissions Submission[]
}

model Submission {
  id          String   @id @default(uuid())
  fileUrl     String?
  submittedAt DateTime @default(now())

  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Notice {
  id        String   @id @default(uuid())
  title     String
  content   String
  type      String   // GENERAL, ACADEMIC, EMERGENCY
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)

  senderId String
  sender   User   @relation("Sender", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("Receiver", fields: [receiverId], references: [id])
}
