# ============================================
# Next.js (Vercel বা লোকাল) — ফ্রন্টএন্ড
# ============================================
# Vercel → Project → Settings → Environment Variables এ একই নামে সেট করুন

# প্রোডাকশন: Render Web Service এর URL (শেষে / বাদ দিন)
# উদাহরণ: https://schoolspace-api.onrender.com
NEXT_PUBLIC_API_URL="http://localhost:5000"

# লোকাল Prisma (যদি রুট অ্যাপে ব্যবহার করেন) — Vercel এ লাগে না
# DATABASE_URL="file:./dev.db"
